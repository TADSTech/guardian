{
  "name": "guardian",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun --cwd apps/web dev",
    "dev:api": "bun --cwd apps/api dev",
    "dev": "concurrently \"bun run dev:api\" \"bun run dev:web\"",
    "build": "bun --cwd apps/web build",
    "lint": "bun --cwd apps/web lint"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
